PORT=5000

# Local MongoDB Compass (for development)
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio

# ── Email Settings (for receiving notifications when someone contacts you) ──
# Use a Gmail account + an App Password (NOT your real Gmail password)
# Get an App Password at: https://myaccount.google.com/apppasswords
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# The email address where you want to receive contact notifications
NOTIFICATION_EMAIL=motombysamuel843@gmail.com

# ── Admin API Key ──
# A random secret to protect GET /api/messages
# Generate one at: https://generate-secret.vercel.app/32
ADMIN_API_KEY=replace_with_a_random_secret_string

# ── Frontend URL (for CORS) ──
# Local dev: http://localhost:3000  |  Production: your Vercel URL
FRONTEND_URL=http://localhost:3000
